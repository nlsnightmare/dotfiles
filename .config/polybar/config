[colors]
background     = ${xrdb:color0:#222}
background-alt = ${xrdb:color7:#222}
foreground     = ${xrdb:color7:#222}
foreground-alt = #FFFFFF
; foreground-alt = ${xrdb:color0:#222}

border         = ${xrdb:color3:#222}
primary        = #ffffff
secondary      = #e60053
alert          = #bd2c40

[bar/bspwm]
width = 100%
height = 40
; offset-x = 1%
; offset-y = 100%
; radius = 6.0
radius = 0.0
; fixed-center = true

background = ${colors.background}
foreground = #ffffff

line-size = 4
line-color = #f00

border-top-size = 0
border-bottom-size = 1
border-left-size = 0
border-right-size = 0
border-color = ${colors.border}

padding-left = 0
padding-right = 1

module-margin-left = 1
module-margin-right = 1

; font-0 = Joystix:pixelsize=10;1
; font-0 = Input Mono:pixelsize=13;1
; font-0 = Iosevka:pixelsize=14:antialias=true;1
; font-0 = DeJaVu Sans Mono:pixelsize=14:antialias=true;1
font-0 = Iosevka:pixelsize=16:antialias=true;1
font-1 = unifont:fontformat=truetype:size=8:antialias=false;0
font-2 = siji:pixelsize=10;1
font-3 = "FontAwesome:fontformat=truetype:pixelsize=12;3"
font-4 = "Font Awesome 5 Free:style=Regular:pixelsize=12;3"
font-5 = "Font Awesome 5 Free:style=Solid:pixelsize=12;3"
font-6 = "Font Awesome 5 Brands:style=Regular:pixelsize=12;3"

modules-left = bspwm
modules-center = mpd
modules-right = pulseaudio date network 

tray-position = right
tray-padding = 1
tray-transparent = true
tray-background = ${xrdb:color3:#222}

wm-restack = bspwm
;wm-restack = i3

;override-redirect = true

;scroll-up = bspwm-desknext
;scroll-down = bspwm-deskprev

;scroll-up = i3wm-wsnext
;scroll-down = i3wm-wsprev

cursor-click = pointer
cursor-scroll = ns-resize

[bar/example]
width = 100%
height = 26
; offset-x = 1%
; offset-y = 100%
; radius = 6.0
radius = 0.0
; fixed-center = true

background = ${colors.background}
foreground = #ffffff

line-size = 4
line-color = #f00

border-top-size = 0
border-bottom-size = 2
border-left-size = 0
border-right-size = 0
border-color = ${colors.border}

padding-left = 0
padding-right = 1

module-margin-left = 1
module-margin-right = 1

; font-0 = Joystix:pixelsize=10;1
; font-0 = Input Mono:pixelsize=13;1
; font-0 = Iosevka:pixelsize=14:antialias=true;1
; font-0 = DeJaVu Sans Mono:pixelsize=14:antialias=true;1
font-0 = Iosevka:pixelsize=14:antialias=true;1
font-1 = unifont:fontformat=truetype:size=8:antialias=false;0
font-2 = siji:pixelsize=10;1
font-3 = "FontAwesome:fontformat=truetype:pixelsize=12;3"
font-4 = "Font Awesome 5 Free:style=Regular:pixelsize=12;3"
font-5 = "Font Awesome 5 Free:style=Solid:pixelsize=12;3"
font-6 = "Font Awesome 5 Brands:style=Regular:pixelsize=12;3"

modules-left = i3 title
modules-center = mpd
modules-right = pulseaudio date network 

tray-position = right
tray-padding = 2
tray-transparent = true
tray-background = ${xrdb:color3:#222}

;wm-restack = bspwm
wm-restack = i3

;override-redirect = true

;scroll-up = bspwm-desknext
;scroll-down = bspwm-deskprev

;scroll-up = i3wm-wsnext
;scroll-down = i3wm-wsprev

cursor-click = pointer
cursor-scroll = ns-resize

; Required for i3
[module/bspwm]
type = internal/bspwm

label-focused = %name%

label-focused-background = ${colors.border}
label-focused-underline = ${colors.border}
label-focused-foreground = ${colors.foreground-alt}
label-focused-padding = 2

label-occupied = %name%
label-occupied-padding = 2

label-urgent = %name%!
label-urgent-background = ${colors.alert}
label-urgent-padding = 2

label-empty = %name%
label-empty-foreground = ${colors.foreground-alt}
label-empty-padding = 2

; Separator in between workspaces
; label-separator = |

[module/i3]
type = internal/i3
format = <label-state> <label-mode>
index-sort = true
wrapping-scroll = false

strip-wsnumbers = true


; Only show workspaces on the same output as the bar
pin-workspaces = true

label-mode-padding = 2
label-mode-foreground = #000
label-mode-background = ${colors.primary}

; focused = Active workspace on focused monitor
label-focused = %name%
label-focused-foreground = ${colors.foreground-alt}

; label-focused-background = ${colors.background-alt}
;label-focused-underline = ${colors.background-alt}
label-focused-background = ${colors.border}
label-focused-underline = ${colors.border}

label-focused-padding = ${module/bspwm.label-focused-padding}

; unfocused = Inactive workspace on any monitor
label-unfocused = %name%
label-unfocused-padding = ${module/bspwm.label-occupied-padding}

; visible = Active workspace on unfocused monitor
label-visible = %name%
label-visible-background = ${self.label-focused-background}
label-visible-underline = ${self.label-focused-underline}
label-visible-padding = ${self.label-focused-padding}

; urgent = Workspace with urgency hint set
label-urgent = ÔĀĪ %name% 
label-urgent-background = ${colors.border}
label-urgent-padding = ${module/bspwm.label-urgent-padding}

; Separator in between workspaces
; label-separator = |


[module/pulseaudio]
type = internal/pulseaudio

use-ui-max = false
format-volume = <ramp-volume> <label-volume>

label-muted = muted
label-muted-foreground = #666
ramp-volume-0 = ÔÄß
ramp-volume-1 = ÔÄ®
ramp-volume-2 = ÔÄ®


; Interval for volume increase/decrease (in percent points) (unreleased)
interval = 5

[module/date]
type = internal/date
interval = 1.0

format = ÔÄó <date>

; See "http://en.cppreference.com/w/cpp/io/manip/put_time" for details on how to format the date string
; NOTE: if you want to use syntax tags here you need to use %%{...}
date = %H:%M:%S

; Optional time format
time = %H:%M
date-alt = %A, %d %B %Y
time-alt = %H:%M:%S

[module/title]
type = internal/xwindow
; Available tags:
;   <label> (default)
format = <label>
; format-background = ${colors.background}
format-foreground = $ffffff
format-padding = 2

; Available tokens:
;   %title%
; Default: %title%
label = %title%
label-maxlen = 20

; Used instead of label when there is no window title
; Available tokens:
;   None
label-empty = 
label-empty-foreground = #707880


[module/network]
type = internal/network
interface=enp27s0
interval = 3.0

unknown-as-up = true
format-connected = ÔÄí 
format-disconnected = ÔĀĪ

label-connected-foreground = #eefafafa
label-disconnected = not connected
label-disconnected-foreground = #66ffffff


[module/mpd]
type = internal/mpd

; Host where mpd is running (either ip or domain name)
; Can also be the full path to a unix socket where mpd is running.
host = 127.0.0.1
port = 6600
; Available tags:
;   <label-offline>
format-offline = MPD IS OFFLINE

; Available tokens:
;   %artist%
;   %album-artist%
;   %album%
;   %date%
;   %title%
; Default: %artist% - %title%
label-song = %artist% - %title%

; Available tokens:
;   %elapsed%
;   %total%
; Default: %elapsed% / %total%
label-time = [%elapsed% / %total%]

; Available tokens:
;   None
label-offline = ūüéú mpd is offline

; Only applies if <icon-X> is used
icon-play = ÔĀč
icon-pause = ÔĀĆ
icon-stop = B
icon-prev = ‚Źģ
icon-next = ‚Ź≠
icon-seekb = ‚Ź™
icon-seekf = ‚Ź©
icon-random = ūüĒÄ
icon-repeat = ūüĒĀ
icon-repeatone = ūüĒā
icon-single = ūüĒā
icon-consume = ‚úÄ

; Used to display the state of random/repeat/repeatone/single
; Only applies if <icon-[random|repeat|repeatone|single]> is used
toggle-on-foreground = #ff
toggle-off-foreground = #55

; Only applies if <bar-progress> is used
bar-progress-width = 20
bar-progress-indicator = >
bar-progress-fill = =
bar-progress-empty = -


; Seconds to sleep between progressbar/song timer sync
; Default: 1
interval = 1
; Available tags:
;   <label-song> (default)
;   <label-time>
;   <bar-progress>
;   <toggle> - gets replaced with <icon-(pause|play)>
;   <toggle-stop> - gets replaced with <icon-(stop|play)>
;   <icon-random>
;   <icon-repeat>
;   <icon-repeatone> (deprecated)
;   <icon-single> - Toggle playing only a single song. Replaces <icon-repeatone>
;   <icon-consume>
;   <icon-prev>
;   <icon-stop>
;   <icon-play>
;   <icon-pause>
;   <icon-next>
;   <icon-seekb>
;   <icon-seekf>
; format-online = mpd is online
format-playing  = <label-song> <label-time>
format-paused   = paused
format-stopped  = MPD OFFLINE!


